DB_HOST=localhost
DB_PORT=3306
DB_NAME=reitinerary
DB_USER=root
DB_PASS=

APP_DEBUG=false
APP_BASE_PATH=
SITE_URL=http://localhost:5173

# SSO: separate DB for shared auth (re-login app owns this DB)
# Defaults to same host/user/pass as above, just a different dbname
SSO_DB_NAME=relogin

# Comma-separated allowed origins for CORS (must match frontend origin exactly)
ALLOWED_ORIGINS=http://localhost:5173

# Set to .rendrahutama.my.id in production, leave empty for localhost dev
COOKIE_DOMAIN=
